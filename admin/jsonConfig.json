{
  "type": "panel",
  "i18n": true,
  "items": {
    "_h_auth": {
      "type": "staticText",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Authentication",
      "style": { "fontWeight": "bold", "fontSize": "15px", "marginTop": "4px" }
    },
    "accessToken": {
      "newLine": true,
      "type": "password",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6,
      "label": "Access Token",
      "tooltip": "Access Token Tooltip"
    },
    "_token_link": {
      "newLine": true,
      "type": "staticText",
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Token Link",
      "style": { "color": "#1976d2", "fontSize": "13px", "marginBottom": "8px" }
    },

    "_h_site": {
      "type": "staticText",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Installation",
      "style": { "fontWeight": "bold", "fontSize": "15px", "marginTop": "12px" }
    },
    "idSite": {
      "newLine": true,
      "type": "text",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6,
      "label": "Installation ID (idSite)",
      "tooltip": "Installation ID Tooltip",
      "validator": "/^[0-9]+$/.test(data.idSite)",
      "validatorErrorText": "Only numbers allowed"
    },

    "_h_poll": {
      "type": "staticText",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Polling Intervals",
      "style": { "fontWeight": "bold", "fontSize": "15px", "marginTop": "12px" }
    },
    "pollInterval": {
      "newLine": true,
      "type": "number",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6,
      "label": "Diagnostics Interval (seconds)",
      "tooltip": "Diagnostics Interval Tooltip",
      "min": 10,
      "max": 3600,
      "default": 60
    },
    "statsInterval": {
      "newLine": true,
      "type": "number",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6,
      "label": "Overall Stats Interval (seconds)",
      "tooltip": "Overall Stats Interval Tooltip",
      "min": 60,
      "max": 86400,
      "default": 300
    },

    "_rate_hint": {
      "newLine": true,
      "type": "staticText",
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Rate Limit Info",
      "style": { "color": "#888", "fontSize": "12px", "marginTop": "12px" }
    },
    "_sensor_info": {
      "newLine": true,
      "type": "staticText",
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "text": "Sensor Count Info",
      "style": { "color": "#555", "fontSize": "12px", "marginTop": "4px" }
    }
  }
}
